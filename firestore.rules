rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ─────────────────────────────────────────────────────────────
    // Public read. Authenticated users can only write their own profile.
    // Allow create/update so the profile upsert (setDoc merge) always works
    // right after Firebase Auth account creation (handles token propagation).
    match /users/{uid} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    // ── Tracks ────────────────────────────────────────────────────────────
    // Public read. Only authenticated users can create their own tracks.
    // Owners can update/delete. Anyone authenticated can increment likes.
    match /tracks/{trackId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 80
        // Enforce free-plan upload limit (2) by reading user's profile
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('plan', 'free') != 'free'
          || (
            !('stats' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data)
            || !('uploads' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.stats)
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.stats.uploads < 2
          )
        );
      allow update: if request.auth != null && (
        // Owner can update anything
        resource.data.uid == request.auth.uid
        // Anyone authenticated can increment/decrement likes only
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
      );
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // ── Likes ─────────────────────────────────────────────────────────────
    // Public read. Users can only create/delete their own like documents.
    match /likes/{likeId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // ── Discovery & Recognition ─────────────────────────────────────────
    match /liveFeed/{itemId} {
      allow read: if true;
      // Allow authenticated users to append live feed items (limited fields)
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.message is string
        && (request.resource.data.trackId is string || !('trackId' in request.resource.data) )
        && (request.resource.data.type is string || !('type' in request.resource.data));
      allow delete, update: if false;
    }

    match /awards/{awardId} {
      allow read: if true;
      // Only admins may create awards
      allow create: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow update, delete: if false;
    }

    match /weeklyWinners/{winnerId} {
      allow read: if true;
      allow create: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow update, delete: if false;
    }

    match /opportunities/{oppId} {
      allow read: if true;
      allow create: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow update, delete: if false;
    }

    // ── Playlists ─────────────────────────────────────────────────────────
    match /playlists/{playlistId} {
      // Public playlists are readable by anyone, private ones only by owner
      allow read: if resource.data.isPublic == true 
                  || (request.auth != null && resource.data.uid == request.auth.uid);
      
      // Only authenticated users can create playlists, and they must own them
      allow create: if request.auth != null 
                    && request.resource.data.uid == request.auth.uid;
      
      // Only the owner can update or delete their playlist
      allow update, delete: if request.auth != null 
                            && resource.data.uid == request.auth.uid;
    }
  }
}
